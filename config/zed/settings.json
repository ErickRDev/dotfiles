// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
  "show_edit_predictions": true,
  "terminal": {
    "shell": {
      "with_arguments": {
        "program": "/opt/homebrew/bin/fish",
        "args": [
          "-c",
          "tmux new-session -A -s \"$(basename \"$PWD\")\" -n \"$(basename \"$PWD\")\"",
        ],
      },
    },
  },
  "icon_theme": {
    "mode": "dark",
    "light": "Zed (Default)",
    "dark": "Zed (Default)",
  },
  "languages": {
    "JSON": { "formatter": "language_server", "format_on_save": "on" },
    "TypeScript": {
      "language_servers": ["typescript-language-server", "!deno"],
    },
    "TSX": {
      "language_servers": ["typescript-language-server", "!deno"],
    },
  },
  "lsp": {
    "metals": {
      "initialization_options": {
        "isHttpEnabled": true,
      },
    },
  },
  "inlay_hints": {
    "enabled": true,
  },
  "agent_servers": {
    "claude-acp": {
      "type": "registry",
    },
  },
  "theme": {
    "mode": "dark",
    "light": "Gruvbox Light Hard",
    "dark": "mutation",
  },
  "vim_mode": true,
  "ui_font_size": 14,
  "buffer_font_size": 14,
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "relative_line_numbers": "enabled",
  "cursor_blink": false,
  "agent": {
    "default_model": {
      "provider": "anthropic",
      "model": "claude-sonnet-4-6",
    },
    "inline_assistant_model": {
      "provider": "anthropic",
      "model": "claude-sonnet-4-6",
    },
  },
}
